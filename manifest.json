{
  "manifest_version": 3,
  "name": "Typing Goal Tracker",
  "version": "1.1",
  "description": "A tool that helps users reach their daily typing goals.",
  "homepage_url": "https://github.com/MysticalRobot/Typing-Goal-Tracker",
  "browser_specific_settings": {
    "gecko": {
      "id": "{f3c0eabd-523c-4704-8601-9ac925c8613c}",
      "data_collection_permissions": {
        "required": ["browsingActivity", "websiteActivity"]
      }
    }
  },
  "icons": {
    "48": "./assets/icon.svg"
  },
  "action": {
    "default_icon": "./assets/icon.svg",
    "default_title": "Typing Goal Tracker",
    "default_popup": "./dist/index.html"
  },
  "background": {
    "scripts": ["./dist/background-script.js"],
    "type": "module"
  },
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "activeTab"
  ],
  "optional_permissions": ["notifications"],
  "optional_host_permissions": ["<all_urls>"],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+0",
        "mac": "Command+Shift+0"
      },
      "description": "toggle the popup"
    }
  }
}
