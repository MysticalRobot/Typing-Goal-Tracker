{
	"name": "Typing-Goal-Tracker",
	"devDependencies": {
		"@types/firefox-webext-browser": "^120.0.5",
		"typescript": "^6.0.3"
	},
	"private": true,
	"scripts": {
		"build": "rm -rf ./dist && bun build.js && web-ext build --overwrite-dest",
		"dev": "bun run build && web-ext run --devtools",
		"zen": "bun run build && web-ext run --devtools --firefox-binary /Applications/Zen.app/Contents/MacOS/zen"
	}
}
